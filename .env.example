# Slack App credentials — get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token   # only needed for Socket Mode

# App config
PORT=3000
NODE_ENV=development

# Database (JSON file)
DB_PATH=./churros.json

# Optional: seed the channel without running /churros enable first
# CHANNEL_ID=C0000000000
