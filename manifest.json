{
  "display_information": {
    "name": "Churros",
    "description": "Open-source Donut clone for Slack — random intro pairings",
    "background_color": "#e8a317"
  },
  "features": {
    "bot_user": {
      "display_name": "Churros",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/churros",
        "description": "Manage random intro pairings",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:read",
        "channels:join",
        "groups:read",
        "users:read",
        "im:write",
        "im:history",
        "mpim:write",
        "chat:write",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "member_joined_channel",
        "member_left_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": true
  }
}
